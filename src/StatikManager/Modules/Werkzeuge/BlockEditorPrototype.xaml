<Window x:Class="StatikManager.Modules.Werkzeuge.BlockEditorPrototype"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="BlockEditor Prototype – Physische Blocktrennung"
        Width="1100" Height="740"
        WindowStartupLocation="CenterOwner">
    <DockPanel>

        <!-- Toolbar -->
        <Border DockPanel.Dock="Top"
                Background="#EFEFEF"
                BorderBrush="#CCCCCC"
                BorderThickness="0,0,0,1"
                Padding="8,6">
            <StackPanel Orientation="Horizontal" VerticalAlignment="Center">

                <Button x:Name="BtnLoad"
                        Content="Bild laden"
                        Width="100" Height="28"
                        Margin="0,0,6,0"
                        Click="BtnLoad_Click"/>

                <Separator Margin="4,2"/>

                <ToggleButton x:Name="BtnCutMode"
                              Content="✂  Schneiden"
                              Width="100" Height="28"
                              Margin="6,0,6,0"
                              Checked="BtnCutMode_Checked"
                              Unchecked="BtnCutMode_Unchecked"/>

                <Separator Margin="4,2"/>

                <TextBlock x:Name="TxtStatus"
                           VerticalAlignment="Center"
                           FontSize="11"
                           Foreground="#333333"
                           Margin="8,0"/>
            </StackPanel>
        </Border>

        <!-- Blockliste links -->
        <Border DockPanel.Dock="Left"
                Width="220"
                BorderBrush="#CCCCCC"
                BorderThickness="0,0,1,0"
                Background="#F8F8F8">
            <DockPanel>
                <Border DockPanel.Dock="Top"
                        Background="#E2E2E2"
                        BorderBrush="#CCCCCC"
                        BorderThickness="0,0,0,1"
                        Padding="8,5">
                    <TextBlock Text="Blöcke" FontWeight="Bold" FontSize="12"/>
                </Border>
                <ListBox x:Name="BlockList"
                         BorderThickness="0"
                         FontFamily="Consolas"
                         FontSize="11"
                         SelectionChanged="BlockList_SelectionChanged"/>
            </DockPanel>
        </Border>

        <!-- Canvas-Bereich -->
        <ScrollViewer HorizontalScrollBarVisibility="Auto"
                      VerticalScrollBarVisibility="Auto"
                      Background="#666666">
            <Canvas x:Name="EditorCanvas"
                    Background="Transparent"
                    MouseLeftButtonDown="EditorCanvas_MouseLeftButtonDown"/>
        </ScrollViewer>

    </DockPanel>
</Window>
