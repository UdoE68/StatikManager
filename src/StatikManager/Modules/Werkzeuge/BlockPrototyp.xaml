<Window x:Class="StatikManager.Modules.Werkzeuge.BlockPrototyp"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Block-Prototyp – Physische Trennung"
        Width="1050" Height="720"
        WindowStartupLocation="CenterOwner">
    <DockPanel>

        <!-- ── Toolbar ─────────────────────────────────────────────────────── -->
        <Border DockPanel.Dock="Top"
                Background="#F0F0F0"
                BorderThickness="0,0,0,1"
                BorderBrush="#CCCCCC"
                Padding="8,5">
            <StackPanel Orientation="Horizontal" VerticalAlignment="Center">

                <Button x:Name="BtnLaden"
                        Content="Bild laden"
                        Padding="10,4"
                        Margin="0,0,6,0"
                        Click="BtnLaden_Click"/>

                <Separator Margin="4,0"/>

                <ToggleButton x:Name="BtnSchnittModus"
                              Content="✂  Schnitt-Modus"
                              Padding="10,4"
                              Margin="0,0,6,0"
                              Checked="BtnSchnittModus_Checked"
                              Unchecked="BtnSchnittModus_Unchecked"/>

                <Separator Margin="4,0"/>

                <TextBlock x:Name="TxtInfo"
                           VerticalAlignment="Center"
                           Foreground="#444444"
                           FontSize="11"
                           Margin="6,0"/>
            </StackPanel>
        </Border>

        <!-- ── Block-Liste links ────────────────────────────────────────────── -->
        <Border DockPanel.Dock="Left"
                Width="210"
                BorderThickness="0,0,1,0"
                BorderBrush="#CCCCCC"
                Background="#FAFAFA">
            <DockPanel>
                <Border DockPanel.Dock="Top"
                        Background="#E8E8E8"
                        BorderThickness="0,0,0,1"
                        BorderBrush="#CCCCCC"
                        Padding="8,5">
                    <TextBlock Text="Blöcke"
                               FontWeight="SemiBold"
                               FontSize="12"/>
                </Border>
                <ListBox x:Name="LstBlöcke"
                         BorderThickness="0"
                         FontFamily="Consolas"
                         FontSize="11"
                         SelectionChanged="LstBlöcke_SelectionChanged"/>
            </DockPanel>
        </Border>

        <!-- ── Canvas-Bereich rechts ────────────────────────────────────────── -->
        <ScrollViewer HorizontalScrollBarVisibility="Auto"
                      VerticalScrollBarVisibility="Auto"
                      Background="#777777">
            <Canvas x:Name="ProtoCanvas"
                    Background="Transparent"
                    MouseLeftButtonDown="ProtoCanvas_MouseLeftButtonDown"/>
        </ScrollViewer>

    </DockPanel>
</Window>
