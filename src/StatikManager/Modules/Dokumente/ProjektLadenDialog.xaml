<Window x:Class="StatikManager.Modules.Dokumente.ProjektLadenDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Projekt öffnen"
        Width="500" Height="242"
        MinWidth="400"
        ResizeMode="NoResize"
        WindowStartupLocation="CenterOwner"
        ShowInTaskbar="False">

    <DockPanel Margin="20,16,20,16">

        <!-- ── Schaltflächen (unten) ─────────────────────────────────────── -->
        <StackPanel DockPanel.Dock="Bottom"
                    Orientation="Horizontal"
                    HorizontalAlignment="Right"
                    Margin="0,16,0,0">
            <Button Content="Öffnen"
                    IsDefault="True"
                    Click="BtnÖffnen_Click"
                    Width="88"
                    Margin="0,0,8,0"/>
            <Button Content="Abbrechen"
                    IsCancel="True"
                    Click="BtnAbbrechen_Click"
                    Width="88"/>
        </StackPanel>

        <!-- ── Inhalt ────────────────────────────────────────────────────── -->
        <StackPanel>

            <!-- Standardpfad -->
            <TextBlock Text="Standardpfad"
                       FontWeight="SemiBold"
                       Margin="0,0,0,6"/>
            <DockPanel Margin="0,0,0,14">
                <Button x:Name="BtnStandardÖffnen"
                        DockPanel.Dock="Right"
                        Content="Direkt öffnen"
                        ToolTip="Standardpfad sofort öffnen ohne weiteren Dialog"
                        Click="BtnStandardÖffnen_Click"
                        IsEnabled="False"
                        Margin="8,0,0,0"/>
                <Border BorderBrush="{DynamicResource Farbe.Rahmen}"
                        BorderThickness="1"
                        Background="{DynamicResource Farbe.Hintergrund}"
                        Padding="8,5">
                    <TextBlock x:Name="TxtStandardpfadAnzeige"
                               TextTrimming="CharacterEllipsis"
                               VerticalAlignment="Center"
                               Foreground="{DynamicResource Farbe.TextSekunder}"/>
                </Border>
            </DockPanel>

            <!-- Trennlinie -->
            <Rectangle Height="1"
                       Fill="{DynamicResource Farbe.Rahmen}"
                       Margin="0,0,0,14"/>

            <!-- Anderen Ordner wählen -->
            <TextBlock Text="Anderen Ordner wählen"
                       FontWeight="SemiBold"
                       Margin="0,0,0,6"/>
            <DockPanel>
                <Button DockPanel.Dock="Right"
                        Content="…"
                        ToolTip="Ordner durchsuchen"
                        Click="BtnDurchsuchen_Click"
                        Width="36"
                        Margin="8,0,0,0"/>
                <TextBox x:Name="TxtPfad"
                         VerticalContentAlignment="Center"/>
            </DockPanel>

        </StackPanel>
    </DockPanel>
</Window>
