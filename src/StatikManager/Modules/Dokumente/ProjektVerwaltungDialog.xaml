<Window x:Class="StatikManager.Modules.Dokumente.ProjektVerwaltungDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Projekte verwalten"
        Width="660" Height="420"
        MinWidth="480" MinHeight="300"
        WindowStartupLocation="CenterOwner"
        ShowInTaskbar="False"
        ResizeMode="CanResizeWithGrip">

    <Grid Margin="12">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="8"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="10"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="*"/>
            <ColumnDefinition Width="8"/>
            <ColumnDefinition Width="110"/>
        </Grid.ColumnDefinitions>

        <!-- ── Hinweiszeile ────────────────────────────────────────────────── -->
        <TextBlock Grid.Row="0" Grid.ColumnSpan="3"
                   FontSize="11" Foreground="#555"
                   Text="Aktiviere Projekte die im Dropdown erscheinen sollen. Kurzname ist optional (leer = Ordnername)."/>

        <!-- ── Projektliste ────────────────────────────────────────────────── -->
        <DataGrid Grid.Row="2" Grid.Column="0"
                  x:Name="DgProjekte"
                  AutoGenerateColumns="False"
                  CanUserAddRows="False"
                  CanUserDeleteRows="False"
                  CanUserReorderColumns="False"
                  SelectionUnit="FullRow"
                  SelectionMode="Single"
                  HeadersVisibility="Column"
                  GridLinesVisibility="Horizontal"
                  BorderBrush="#CCC" BorderThickness="1"
                  RowHeight="28"
                  FontSize="12"
                  SelectionChanged="DgProjekte_SelectionChanged">

            <DataGrid.Columns>

                <!-- Checkbox: im Dropdown sichtbar -->
                <DataGridTemplateColumn Header="✓" Width="36" CanUserResize="False">
                    <DataGridTemplateColumn.CellTemplate>
                        <DataTemplate>
                            <CheckBox IsChecked="{Binding Sichtbar, UpdateSourceTrigger=PropertyChanged, Mode=TwoWay}"
                                      HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </DataTemplate>
                    </DataGridTemplateColumn.CellTemplate>
                </DataGridTemplateColumn>

                <!-- Kurzname (editierbar) -->
                <DataGridTextColumn Header="Kurzname (optional)"
                                    Binding="{Binding Kurzname, UpdateSourceTrigger=PropertyChanged}"
                                    Width="165"/>

                <!-- Pfad (read-only) -->
                <DataGridTextColumn Header="Pfad"
                                    Binding="{Binding Pfad}"
                                    Width="*"
                                    IsReadOnly="True">
                    <DataGridTextColumn.ElementStyle>
                        <Style TargetType="TextBlock">
                            <Setter Property="Foreground" Value="#555"/>
                            <Setter Property="TextTrimming" Value="CharacterEllipsis"/>
                            <Setter Property="ToolTip" Value="{Binding Pfad}"/>
                        </Style>
                    </DataGridTextColumn.ElementStyle>
                </DataGridTextColumn>

            </DataGrid.Columns>
        </DataGrid>

        <!-- ── Seitenbuttons ───────────────────────────────────────────────── -->
        <StackPanel Grid.Row="2" Grid.Column="2"
                    Orientation="Vertical"
                    VerticalAlignment="Top">

            <Button x:Name="BtnHinzufügen"
                    Content="＋ Hinzufügen"
                    Height="28" Margin="0,0,0,4"
                    FontSize="11"
                    ToolTip="Projektordner auswählen und zur Liste hinzufügen"
                    Click="BtnHinzufügen_Click"/>

            <Button x:Name="BtnEntfernen"
                    Content="− Entfernen"
                    Height="28" Margin="0,0,0,16"
                    FontSize="11"
                    IsEnabled="False"
                    ToolTip="Ausgewählten Eintrag aus der Liste entfernen (Dateien bleiben erhalten)"
                    Click="BtnEntfernen_Click"/>

            <Button x:Name="BtnNachOben"
                    Content="↑ Nach oben"
                    Height="28" Margin="0,0,0,4"
                    FontSize="11"
                    IsEnabled="False"
                    Click="BtnNachOben_Click"/>

            <Button x:Name="BtnNachUnten"
                    Content="↓ Nach unten"
                    Height="28"
                    FontSize="11"
                    IsEnabled="False"
                    Click="BtnNachUnten_Click"/>

        </StackPanel>

        <!-- ── OK / Abbrechen ─────────────────────────────────────────────── -->
        <StackPanel Grid.Row="4" Grid.ColumnSpan="3"
                    Orientation="Horizontal"
                    HorizontalAlignment="Right">
            <Button Content="OK"
                    Width="80" Height="26"
                    IsDefault="True"
                    Margin="0,0,8,0"
                    Click="BtnOK_Click"/>
            <Button Content="Abbrechen"
                    Width="90" Height="26"
                    IsCancel="True"
                    Click="BtnAbbrechen_Click"/>
        </StackPanel>

    </Grid>
</Window>
