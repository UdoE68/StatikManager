<UserControl x:Class="StatikManager.Modules.Dokumente.DokumentePanel"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:wz="clr-namespace:StatikManager.Modules.Werkzeuge">

    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="300" MinWidth="180"/>
            <ColumnDefinition Width="5"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <!-- ── Linke Seite: Kopfzeile + Dokumentenliste ─────────────────── -->
        <DockPanel x:Name="LinkeSeite"
                   Grid.Column="0"
                   Background="{DynamicResource Farbe.Fläche}">

            <!-- Kopfzeile mit Titel und Ansicht-Umschalter -->
            <Border DockPanel.Dock="Top"
                    Background="{DynamicResource Farbe.Fläche}"
                    BorderBrush="{DynamicResource Farbe.Rahmen}"
                    BorderThickness="0,0,0,1"
                    Padding="10,7,8,7">
                <DockPanel>
                    <TextBlock Text="Dokumente"
                               FontWeight="SemiBold"
                               FontSize="13"
                               VerticalAlignment="Center"/>

                    <!-- Segmented Toggle: Baum / Liste -->
                    <Border DockPanel.Dock="Right"
                            HorizontalAlignment="Right"
                            BorderBrush="{DynamicResource Farbe.Rahmen}"
                            BorderThickness="1"
                            CornerRadius="4"
                            ClipToBounds="True">
                        <StackPanel Orientation="Horizontal">
                            <RadioButton x:Name="RbBaum"
                                         Content="🌳 Baum"
                                         ToolTip="Baumstruktur (Ordner und Dateien)"
                                         IsChecked="True"
                                         GroupName="Ansicht"
                                         Style="{StaticResource AnsichtToggle}"
                                         Click="Ansicht_Geändert"/>
                            <RadioButton x:Name="RbListe"
                                         Content="📋 Liste"
                                         ToolTip="Alle Dateien ohne Ordnerstruktur"
                                         GroupName="Ansicht"
                                         Style="{StaticResource AnsichtToggle}"
                                         Click="Ansicht_Geändert"/>
                        </StackPanel>
                    </Border>
                </DockPanel>
            </Border>

            <!-- Filterleiste + Baumtiefe -->
            <Border DockPanel.Dock="Top"
                    Background="{DynamicResource Farbe.Fläche}"
                    BorderBrush="{DynamicResource Farbe.Rahmen}"
                    BorderThickness="0,0,0,1"
                    Padding="10,5,8,5">
                <DockPanel>
                    <TextBlock Text="Typ:"
                               VerticalAlignment="Center"
                               Margin="0,0,6,0"
                               FontSize="12"/>
                    <ComboBox x:Name="CbBaumTiefe"
                              FontSize="11"
                              Width="88"
                              DockPanel.Dock="Right"
                              Margin="4,0,0,0"
                              ToolTip="Sichtbare Ebenen im Baum"
                              SelectionChanged="CbBaumTiefe_SelectionChanged"/>
                    <TextBlock Text="Ebenen:"
                               DockPanel.Dock="Right"
                               VerticalAlignment="Center"
                               Margin="8,0,4,0"
                               FontSize="11"/>
                    <ComboBox x:Name="CbFilter"
                              FontSize="12"
                              SelectionChanged="CbFilter_SelectionChanged"/>
                </DockPanel>
            </Border>

            <!-- Baumstruktur und flache Liste übereinander (je eins sichtbar) -->
            <Grid>
                <TreeView x:Name="DokumentenBaum"
                          SelectedItemChanged="DokumentenBaum_SelectedItemChanged"
                          FontSize="13"
                          ScrollViewer.HorizontalScrollBarVisibility="Auto"
                          ContextMenuOpening="DokumentenBaum_ContextMenuOpening"
                          TreeViewItem.RequestBringIntoView="DokumentenBaum_RequestBringIntoView"
                          PreviewMouseLeftButtonDown="DokumentenBaum_PreviewMouseDown"
                          PreviewKeyDown="DokumentenBaum_PreviewKeyDown">
                    <TreeView.ContextMenu>
                        <ContextMenu/>
                    </TreeView.ContextMenu>
                </TreeView>

                <ListView x:Name="DateiListe"
                          Visibility="Collapsed"
                          SelectionMode="Extended"
                          SelectionChanged="DateiListe_SelectionChanged"
                          FontSize="13"
                          BorderThickness="0"
                          ContextMenuOpening="DateiListe_ContextMenuOpening"
                          PreviewKeyDown="DateiListe_PreviewKeyDown">
                    <ListView.ContextMenu>
                        <ContextMenu/>
                    </ListView.ContextMenu>
                    <ListView.View>
                        <GridView>
                            <GridViewColumn Header="Dateiname" Width="165">
                                <GridViewColumn.CellTemplate>
                                    <DataTemplate>
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="Auto"/>
                                            </Grid.ColumnDefinitions>
                                            <TextBlock Grid.Column="0"
                                                       Text="{Binding Dateiname}"
                                                       VerticalAlignment="Center"/>
                                            <Button Grid.Column="1"
                                                    Content="🗑"
                                                    Padding="3,0"
                                                    ToolTip="Auswahl löschen"
                                                    Click="BtnZeileLöschen_Click">
                                                <Button.Style>
                                                    <Style TargetType="Button">
                                                        <Setter Property="Visibility" Value="Collapsed"/>
                                                        <Style.Triggers>
                                                            <DataTrigger Value="True"
                                                                         Binding="{Binding IsSelected,
                                                                             RelativeSource={RelativeSource
                                                                                 AncestorType=ListViewItem}}">
                                                                <Setter Property="Visibility" Value="Visible"/>
                                                            </DataTrigger>
                                                        </Style.Triggers>
                                                    </Style>
                                                </Button.Style>
                                            </Button>
                                        </Grid>
                                    </DataTemplate>
                                </GridViewColumn.CellTemplate>
                            </GridViewColumn>
                            <GridViewColumn Header="Ordner"
                                            DisplayMemberBinding="{Binding OrdnerRelativ}"/>
                        </GridView>
                    </ListView.View>
                </ListView>
            </Grid>

        </DockPanel>

        <!-- ── Teilungsbalken ────────────────────────────────────────────── -->
        <GridSplitter Grid.Column="1"
                      Width="5"
                      HorizontalAlignment="Stretch"/>

        <!-- ── Rechte Seite: Vorschau ─────────────────────────────────────── -->
        <Grid Grid.Column="2">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <TextBlock Grid.Row="0"
                       Text="Vorschau"
                       FontWeight="SemiBold"
                       FontSize="13"
                       Margin="10,10,10,0"/>

            <!-- Abdeckungs-Panel (nur für PDF-Dateien sichtbar) -->
            <Border x:Name="AbdeckungsPanel"
                    Grid.Row="1"
                    Background="{DynamicResource Farbe.Werkzeugleiste}"
                    BorderBrush="{DynamicResource Farbe.Rahmen}"
                    BorderThickness="0,1,0,1"
                    Padding="10,6"
                    Margin="0,6,0,0"
                    Visibility="Collapsed">
                <WrapPanel>

                    <CheckBox x:Name="ChkKopf"
                              Content="Kopfzeile abdecken"
                              VerticalAlignment="Center"
                              Margin="0,0,8,0"
                              Checked="Abdeckung_Changed"
                              Unchecked="Abdeckung_Changed"/>
                    <TextBox x:Name="TxtKopfMm"
                             Width="44" Text="20"
                             TextAlignment="Right"
                             VerticalAlignment="Center"
                             Margin="0,0,3,0"
                             TextChanged="Abdeckung_Changed"/>
                    <TextBlock Text="mm"
                               VerticalAlignment="Center"
                               Margin="0,0,24,0"/>

                    <CheckBox x:Name="ChkFuss"
                              Content="Fußzeile abdecken"
                              VerticalAlignment="Center"
                              Margin="0,0,8,0"
                              Checked="Abdeckung_Changed"
                              Unchecked="Abdeckung_Changed"/>
                    <TextBox x:Name="TxtFussMm"
                             Width="44" Text="20"
                             TextAlignment="Right"
                             VerticalAlignment="Center"
                             Margin="0,0,3,0"
                             TextChanged="Abdeckung_Changed"/>
                    <TextBlock Text="mm" VerticalAlignment="Center"/>

                </WrapPanel>
            </Border>

            <!-- Word-Vorschau-Panel mit Toolbar und Seiten-Scroll -->
            <Border x:Name="WordInfoPanel"
                    Grid.Row="2"
                    Background="{DynamicResource Farbe.Fläche}"
                    Visibility="Collapsed">
                <DockPanel>

                    <!-- ── Toolbar ─────────────────────────────────────── -->
                    <Border DockPanel.Dock="Top"
                            Background="{DynamicResource Farbe.Werkzeugleiste}"
                            BorderBrush="{DynamicResource Farbe.Rahmen}"
                            BorderThickness="0,0,0,1"
                            Padding="8,5">
                        <WrapPanel Orientation="Horizontal" VerticalAlignment="Center">

                            <!-- Zoom -->
                            <TextBlock Text="Zoom:" VerticalAlignment="Center"
                                       FontSize="11" Margin="0,0,4,0"/>
                            <Button x:Name="BtnWordZoomMinus" Content="🔍−"
                                    Width="32" Height="22" FontSize="12" Margin="0,0,2,0"
                                    ToolTip="Verkleinern"
                                    Click="BtnWordZoomMinus_Click"/>
                            <Border BorderBrush="#AAA" BorderThickness="1" CornerRadius="3"
                                    Padding="4,1" Margin="0,0,2,0" VerticalAlignment="Center"
                                    Background="White">
                                <TextBlock x:Name="TxtWordZoom" Text="100%"
                                           Width="36" TextAlignment="Center"
                                           FontSize="12" FontWeight="Bold"/>
                            </Border>
                            <Button x:Name="BtnWordZoomPlus" Content="🔍+"
                                    Width="32" Height="22" FontSize="12" Margin="0,0,6,0"
                                    ToolTip="Vergrößern"
                                    Click="BtnWordZoomPlus_Click"/>

                            <Separator Width="1" Height="18" Background="#BBB" Margin="0,0,6,0"/>

                            <!-- Ansichtsmodi -->
                            <Button x:Name="BtnWord100" Content="1:1"
                                    Width="30" Height="22" FontSize="10" Margin="0,0,2,0"
                                    ToolTip="100 % – Originalgröße"
                                    Click="BtnWord100_Click"/>
                            <Button x:Name="BtnWordEineSeite" Content="☐"
                                    Width="28" Height="22" FontSize="13" Margin="0,0,2,0"
                                    ToolTip="Eine Seite – Seite vollständig sichtbar"
                                    Click="BtnWordEineSeite_Click"/>
                            <Button x:Name="BtnWordBreite" Content="↔"
                                    Width="28" Height="22" FontSize="13" Margin="0,0,2,0"
                                    ToolTip="Seitenbreite – volle Breite ausnutzen"
                                    Click="BtnWordBreite_Click"/>
                            <Button x:Name="BtnWordMehrere" Content="⊞"
                                    Width="28" Height="22" FontSize="12" Margin="0,0,6,0"
                                    ToolTip="Mehrere Seiten – Übersicht"
                                    Click="BtnWordMehrere_Click"/>

                            <Separator Width="1" Height="18" Background="#BBB" Margin="0,0,6,0"/>

                            <!-- In Word öffnen -->
                            <Button x:Name="BtnWordÖffnen"
                                    Content="📄 In Word öffnen"
                                    Height="22" Padding="8,0" FontSize="11"
                                    Style="{StaticResource PrimaryButton}"
                                    Click="BtnWordÖffnen_Click"/>

                            <Separator Width="1" Height="18" Background="#BBB" Margin="6,0,6,0"/>

                            <!-- Status -->
                            <TextBlock x:Name="TxtWordDateiname"
                                       VerticalAlignment="Center" FontSize="11"
                                       FontWeight="SemiBold" Foreground="#2b579a"
                                       Margin="0,0,8,0"/>
                            <TextBlock x:Name="TxtWordLadeStatus"
                                       VerticalAlignment="Center" FontSize="11"
                                       Foreground="#888" FontStyle="Italic"/>
                        </WrapPanel>
                    </Border>

                    <!-- ── Seiten-Vorschau ──────────────────────────────── -->
                    <ScrollViewer x:Name="WordScrollViewer"
                                  HorizontalScrollBarVisibility="Auto"
                                  VerticalScrollBarVisibility="Auto"
                                  Background="#4A4A4A"
                                  PreviewMouseWheel="WordScrollViewer_PreviewMouseWheel">
                        <Border HorizontalAlignment="Center" VerticalAlignment="Top">
                            <Border.LayoutTransform>
                                <ScaleTransform x:Name="WordZoomTransform" ScaleX="1" ScaleY="1"/>
                            </Border.LayoutTransform>
                            <StackPanel x:Name="WordSeitenPanel"
                                        Orientation="Vertical"
                                        Margin="16,16,16,16"/>
                        </Border>
                    </ScrollViewer>

                </DockPanel>
            </Border>

            <!-- Bild-Vorschau (für Bilder) -->
            <WebBrowser x:Name="WordVorschau"
                        Grid.Row="2"
                        Visibility="Collapsed"
                        Navigating="WordVorschau_Navigating"
                        LoadCompleted="WordVorschau_LoadCompleted"/>

            <!-- PDF-Schnitt-Editor (für .pdf) -->
            <wz:PdfSchnittEditor x:Name="PdfEditor"
                                 Grid.Row="2"
                                 Visibility="Collapsed"/>

        </Grid>
    </Grid>
</UserControl>
